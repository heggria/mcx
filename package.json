{
  "name": "mcx",
  "version": "0.2.0",
  "description": "Unified catalog CLI for MCP tools AND Claude skills — semantic search + lazy load + audit",
  "type": "module",
  "bin": {
    "mcx": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "examples",
    "README.md"
  ],
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "bun build src/cli.ts --target=bun --external onnxruntime-node --external @xenova/transformers --outfile dist/cli.js && chmod +x dist/cli.js",
    "build:binary": "bun build src/cli.ts --compile --target=bun --outfile dist/mcx",
    "test": "bun test",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@xenova/transformers": "^2.17.2",
    "commander": "^12.1.0",
    "nanoid": "^5.0.9",
    "smol-toml": "^1.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.5",
    "bun-types": "^1.3.13",
    "typescript": "^5.7.2"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "protobufjs",
    "sharp"
  ]
}
